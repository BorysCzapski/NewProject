# ============================================================================
# Environment variables required by the app.
# Copy this file to .env.local for local development
# (`cp .env.example .env.local`) and fill in real values.
# On Vercel, add the same keys under Project Settings -> Environment Variables.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# Project URL and anon (public) key: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key: Supabase Dashboard -> Project Settings -> API (keep secret!)
# Used ONLY in server-only code (route handlers / server actions) that must
# bypass Row Level Security, e.g. looking up an email by username at login,
# or admin-only seeding scripts. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI (Groq) ----------------------------------------------------------------
# https://console.groq.com/keys — Groq has a free tier.
# Used only in server-side code (Server Actions) — never on the client.
GROQ_API_KEY=your-groq-api-key
# Optional: defaults to llama-3.3-70b-versatile if unset.
# GROQ_MODEL=llama-3.3-70b-versatile

# --- App ----------------------------------------------------------------------
# Public base URL of the deployment, used for auth redirect links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- ETF prices (Paragony) -----------------------------------------------------
# Financial Modeling Prep — https://financialmodelingprep.com (free tier: 250
# requests/day, 500 MB/30 days). Used only for foreign (non-GPW) ETF tickers;
# GPW tickers use Stooq, which needs no key. Optional — without it, foreign
# ETF price refresh is skipped (see lib/paragony/etf-prices.ts).
# FMP_API_KEY=your-fmp-api-key
